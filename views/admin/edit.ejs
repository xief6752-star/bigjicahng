<%- include('header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 24px;">
  <h2 style="margin:0;"><%= article.id ? '编辑文章' : '新增文章' %></h2>
  <a href="/admin" class="btn btn-default">返回列表</a>
</div>

<div class="card">
  <form action="/admin/save" method="POST">
    <input type="hidden" name="id" value="<%= article.id || '' %>">
    
    <div style="display: flex; gap: 24px;">
      <div class="form-group" style="flex: 1;">
        <label>类型</label>
        <select name="type" class="form-control">
          <option value="review" <%= article.type === 'review' ? 'selected' : '' %>>评测 (Review)</option>
          <option value="tutorial" <%= article.type === 'tutorial' ? 'selected' : '' %>>教程 (Tutorial)</option>
        </select>
      </div>
      <div class="form-group" style="flex: 1;">
        <label>别名 (Slug, 例如: review-shunyun)</label>
        <input type="text" name="slug" class="form-control" value="<%= article.slug || '' %>" required>
      </div>
    </div>

    <div class="form-group">
      <label>标题</label>
      <input type="text" name="title" class="form-control" value="<%= article.title || '' %>" required>
    </div>

    <div class="form-group">
      <label>副标题</label>
      <input type="text" name="subtitle" class="form-control" value="<%= article.subtitle || '' %>">
    </div>

    <div class="form-group">
      <label style="display:flex; align-items:center; gap:8px; font-weight:normal; cursor:pointer;">
        <input type="checkbox" name="is_pinned" value="1" <%= article.is_pinned === 1 ? 'checked' : '' %>> 设为置顶文章 (在首页大图卡片显示)
      </label>
    </div>

    <div style="display: flex; gap: 24px;">
      <div class="form-group" style="flex: 1;">
        <label>标签 (Tag, 例如: 综合推荐, Windows)</label>
        <input type="text" name="tag" class="form-control" value="<%= article.tag || '' %>">
      </div>
      <div class="form-group" style="flex: 1;">
        <label>日期 (例如: 2026-05-14 更新)</label>
        <input type="text" name="date" class="form-control" value="<%= article.date || '' %>">
      </div>
      <div class="form-group" style="flex: 1;">
        <label>评分 (满分10，仅评测生效)</label>
        <input type="number" step="0.1" name="score" class="form-control" value="<%= article.score || '0' %>">
      </div>
    </div>

    <div class="form-group">
      <label>文章内容 (HTML 格式)</label>
      <textarea name="content" class="form-control"><%= article.content || '' %></textarea>
      <div style="font-size: 12px; color: #888; margin-top: 8px;">* 直接编辑 HTML 内容。你可以使用 <code>&lt;h2&gt;</code>、<code>&lt;p&gt;</code>、<code>&lt;div class="tip"&gt;</code> 等样式。</div>
    </div>

    <div class="form-group" style="margin-top: 32px;">
      <button type="submit" class="btn btn-primary" style="padding: 10px 32px; font-size: 16px;">保存文章</button>
    </div>
  </form>
</div>

<%- include('footer') %>
