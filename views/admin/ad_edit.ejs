<%- include('header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 24px;">
  <h2 style="margin:0;"><%= ad.id ? '编辑广告' : '新增广告' %></h2>
  <a href="/admin/ads" class="btn btn-default">返回列表</a>
</div>

<div class="card" style="max-width: 600px;">
  <form action="/admin/ads/save" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="id" value="<%= ad.id || '' %>">

    <div class="form-group">
      <label>显示文字 (例如: 某某云 | 专线 8折)</label>
      <input type="text" name="title" class="form-control" value="<%= ad.title || '' %>" required>
    </div>

    <div class="form-group">
      <label>跳转链接 (需包含 http:// 或 https://)</label>
      <input type="url" name="link" class="form-control" value="<%= ad.link || '' %>" required>
    </div>

    <div class="form-group" style="border: 1px solid #e0ddd5; padding: 16px; border-radius: 8px;">
      <label style="font-weight: 700; margin-bottom: 12px; display: block;">广告图片 (二选一)</label>
      
      <div style="margin-bottom: 16px;">
        <label>方式 1：本地上传 (会保存到 /public/uploads/ 并在前台生效)</label>
        <input type="file" name="image_file" class="form-control" accept="image/*">
      </div>
      
      <div>
        <label>方式 2：图片链接 URL (如果不上传文件，则使用此链接)</label>
        <input type="url" name="image_url" class="form-control" value="<%= ad.image_url || '' %>">
      </div>
      
      <% if (ad.image_url) { %>
      <div style="margin-top: 16px;">
        <label>当前图片预览：</label>
        <br>
        <img src="<%= ad.image_url %>" style="max-width: 100%; max-height: 120px; border-radius: 4px; border: 1px solid #ddd;">
      </div>
      <% } %>
    </div>

    <div class="form-group">
      <label>排序 (数字越小排越前，默认 0)</label>
      <input type="number" name="sort_order" class="form-control" value="<%= ad.sort_order || '0' %>">
    </div>

    <div class="form-group" style="margin-top: 32px;">
      <button type="submit" class="btn btn-primary" style="padding: 10px 32px; font-size: 16px;">保存广告</button>
    </div>
  </form>
</div>

<%- include('footer') %>
