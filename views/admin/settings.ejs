<%- include('header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 24px;">
  <h2 style="margin:0;">站点设置</h2>
</div>

<div class="card" style="max-width: 800px;">
  <form action="/admin/settings/save" method="POST">
    
    <div style="display: flex; gap: 24px;">
      <div class="form-group" style="flex: 1;">
        <label>主标题第一行 (默认: 不接推广。)</label>
        <input type="text" name="hero_title_1" class="form-control" value="<%= settings.hero_title_1 || '' %>" required>
      </div>
      <div class="form-group" style="flex: 1;">
        <label>主标题第二行 (默认: 只说真话。)</label>
        <input type="text" name="hero_title_2" class="form-control" value="<%= settings.hero_title_2 || '' %>" required>
      </div>
    </div>

    <div class="form-group">
      <label>主页自我介绍 (Hero Description)</label>
      <textarea name="hero_desc" class="form-control" style="min-height: 100px;" required><%= settings.hero_desc || '' %></textarea>
      <div style="font-size: 12px; color: #888; margin-top: 8px;">显示在主页大标题下方。</div>
    </div>

    <div class="form-group">
      <label>主页歌词引用 (Hero Quote)</label>
      <input type="text" name="hero_quote" class="form-control" value="<%= settings.hero_quote || '' %>" required>
    </div>

    <div class="form-group">
      <label>歌词作者/出处 (Hero Quote Author)</label>
      <input type="text" name="hero_quote_author" class="form-control" value="<%= settings.hero_quote_author || '' %>" required>
    </div>

    <div class="form-group">
      <label>关于博主 (About Author)</label>
      <textarea name="about_author" class="form-control" style="min-height: 100px;" required><%= settings.about_author || '' %></textarea>
      <div style="font-size: 12px; color: #888; margin-top: 8px;">显示在主页右侧边栏的“关于博主”卡片中。</div>
    </div>

    <div class="form-group">
      <label>统计代码 (Tracking Code, 如 Google Analytics 或百度统计的 script 标签)</label>
      <textarea name="tracking_code" class="form-control" style="min-height: 100px;" placeholder="<script>...</script>"><%= settings.tracking_code || '' %></textarea>
      <div style="font-size: 12px; color: #888; margin-top: 8px;">这段代码会被插入到所有页面的 <code>&lt;head&gt;</code> 标签中。</div>
    </div>

    <div class="form-group" style="margin-top: 32px;">
      <button type="submit" class="btn btn-primary" style="padding: 10px 32px; font-size: 16px;">保存设置</button>
    </div>
  </form>
</div>

<%- include('footer') %>
